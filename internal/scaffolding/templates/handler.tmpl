// GetAll godoc
// @Summary      List all {{.LowerPlural}}
// @Tags         {{.LowerPlural}}
// @Success      200 {object} response.Response
// @Router       /api/{{.LowerPlural}} [get]
func (h *{{.Name}}Handler) GetAll(c *gin.Context) {
	params := pagination.FromContext(c)
	
	items, total, err := h.service.GetAll(c.Request.Context(), params)
	if err != nil {
		h.log.Error("Failed to get {{.LowerPlural}}", zap.Error(err))
		response.InternalServerError(c, "")
		return
	}

	meta := response.NewMeta(params.Page, params.PerPage, total)
	response.OKWithMeta(c, "Success", resources.New{{.Name}}Collection(items), meta)
}

// GetByID godoc
// @Summary      Get {{.LowerName}} by ID
// @Tags         {{.LowerPlural}}
// @Param        id path int true "ID"
// @Success      200 {object} response.Response
// @Router       /api/{{.LowerPlural}}/{id} [get]
func (h *{{.Name}}Handler) GetByID(c *gin.Context) {
	idStr := c.Param("id")
	id, _ := strconv.ParseUint(idStr, 10, 64)
	
	item, err := h.service.GetByID(c.Request.Context(), id)
	if err != nil {
		if errors.Is(err, domain.ErrNotFound) {
			response.NotFound(c, "{{.Name}} not found")
			return
		}
		response.InternalServerError(c, "")
		return
	}
	response.OK(c, "Success", resources.New{{.Name}}Resource(item))
}

