version: '3.8'

services:
  # Primary Database
  postgres:
    image: 'postgres:16-alpine'
    container_name: '${COMPOSE_PROJECT_NAME:-kodia}-postgres'
    ports:
      - '${FORWARD_DB_PORT:-5432}:5432'
    environment:
      POSTGRES_DB: '${DB_DATABASE:-kodia}'
      POSTGRES_USER: '${DB_USERNAME:-kodia}'
      POSTGRES_PASSWORD: '${DB_PASSWORD:-secret}'
    volumes:
      - 'kodia-postgres:/var/lib/postgresql/data'
    networks:
      - kodia
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USERNAME:-kodia} -d ${DB_DATABASE:-kodia}"]
      interval: 10s
      timeout: 5s
      retries: 5

  # Key-Value Store & Queue
  redis:
    image: 'redis:7-alpine'
    container_name: '${COMPOSE_PROJECT_NAME:-kodia}-redis'
    ports:
      - '${FORWARD_REDIS_PORT:-6379}:6379'
    volumes:
      - 'kodia-redis:/data'
    networks:
      - kodia
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # Full-Text Search Engine
  meilisearch:
    image: 'getmeili/meilisearch:latest'
    container_name: '${COMPOSE_PROJECT_NAME:-kodia}-meilisearch'
    ports:
      - '${FORWARD_MEILISEARCH_PORT:-7700}:7700'
    environment:
      MEILI_MASTER_KEY: '${MEILISEARCH_KEY:-masterKey}'
      MEILI_NO_ANALYTICS: 'true'
    volumes:
      - 'kodia-meilisearch:/meili_data'
    networks:
      - kodia
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:7700/health"]
      interval: 10s
      timeout: 5s
      retries: 5

  # Local SMTP & Email Inspector
  mailpit:
    image: 'axllent/mailpit:latest'
    container_name: '${COMPOSE_PROJECT_NAME:-kodia}-mailpit'
    ports:
      - '${FORWARD_MAILPIT_PORT:-1025}:1025'
      - '${FORWARD_MAILPIT_DASHBOARD_PORT:-8025}:8025'
    networks:
      - kodia

networks:
  kodia:
    driver: bridge

volumes:
  kodia-postgres:
    driver: local
  kodia-redis:
    driver: local
  kodia-meilisearch:
    driver: local
