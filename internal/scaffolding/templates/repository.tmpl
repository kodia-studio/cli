	query := `
		UPDATE {{.LowerPlural}} SET
			{{- range $i, $f := .Fields}}{{if $i}}, {{end}}{{$f.LowerName}} = ${{add $i 1}}{{end}},
			updated_at = CURRENT_TIMESTAMP
		WHERE id = ${{add (len .Fields) 1}} AND deleted_at IS NULL`

	res, err := r.db.ExecContext(ctx, query,
		{{- range .Fields}}
		item.{{.Name}},
		{{- end}}
		item.ID,
	)
	if err != nil {
