func (r *{{.LowerName}}Repository) GetByID(ctx context.Context, id uint64) (*domain.{{.Name}}, error) {
	var item domain.{{.Name}}
	query := "SELECT * FROM {{.LowerPlural}} WHERE id = $1 AND deleted_at IS NULL"
	if err := r.db.GetContext(ctx, &item, query, id); err != nil {
