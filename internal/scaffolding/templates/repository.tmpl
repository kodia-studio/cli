func (r *{{.LowerName}}Repository) Delete(ctx context.Context, id uint64) error {
	query := "UPDATE {{.LowerPlural}} SET deleted_at = CURRENT_TIMESTAMP WHERE id = $1 AND deleted_at IS NULL"
	res, err := r.db.ExecContext(ctx, query, id)
